# =============================================================================
# apps/server — NestJS API
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# --- Auth (JWT for API + session token from NextAuth) ---
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=30d

# --- Google Sign-In (same OAuth app as apps/web) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback/google

# --- Database (PostgreSQL — required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_meeting_agent

# --- App URLs ---
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_URLS=http://localhost:3000

# --- Email (SMTP — required for meeting notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Meetra

# --- Stripe (billing — https://dashboard.stripe.com/test/apikeys) ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRO_PRICE_ID=price_

# --- Recall.ai (Google Meet bot — https://www.recall.ai/) ---
# Use the API base URL for YOUR Recall region (see Recall dashboard → API keys).
RECALL_API_KEY=
# Signing secret from Recall dashboard → Webhooks (starts with whsec_)
RECALL_WEBHOOK_SECRET=
RECALL_BASE_URL=https://us-west-2.recall.ai/api/v1

# --- Mastra agent service (local dev) ---
MASTRA_URL=http://localhost:4111

# --- Google Calendar OAuth (optional — defaults to GOOGLE_CLIENT_* above) ---
# Only needed if you use a separate OAuth client for the reconnect flow.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# --- Encrypt calendar OAuth tokens at rest (openssl rand -hex 32) ---
TOKEN_ENCRYPTION_KEY=

# --- Legacy / optional (required by config.ts but unused in meeting SaaS v1) ---
S3_ACCESS_KEY_ID=local-dev
S3_SECRET_ACCESS_KEY=local-dev
S3_BUCKET_NAME=local-dev
S3_REGION=us-east-1
LOKI_HOST=http://localhost:3100
LOKI_USERNAME=local
LOKI_PASSWORD=local
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
